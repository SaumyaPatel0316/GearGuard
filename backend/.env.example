# MongoDB Atlas connection string
# Get your URI from MongoDB Atlas dashboard: https://cloud.mongodb.com
#MONGODB_URI="mongodb+srv://username:password@cluster-name.mongodb.net/gearguard?retryWrites=true&w=majority"

# Server port
#PORT=5000

# JWT secret for authentication tokens (generate a secure random string)
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#JWT_SECRET="your_secure_jwt_secret_here"

# Node environment
#NODE_ENV="production"

# JWT token expiration
#JWT_EXPIRES_IN="7d"

# Firebase Admin SDK Service Account Key (JSON string)
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
#FIREBASE_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}'
