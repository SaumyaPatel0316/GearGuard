# Firebase Configuration
# Get these values from Firebase Console > Project Settings > General > Your Apps
# Project ID from serviceAccountKey.json: gearguard-2026reserved
#
# FOR DEPLOYMENT (Vercel):
# Set these as environment variables in Vercel dashboard
# All variables must start with VITE_ prefix for Vite to access them
#
# FOR LOCAL DEVELOPMENT:
# Create a .env file in the project root with these values

# Backend API URL
# For local development: http://localhost:5000
# For production: https://your-render-backend-url.onrender.com
VITE_API_URL=http://localhost:5000

# Firebase Config
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=gearguard-2026reserved.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=gearguard-2026reserved
VITE_FIREBASE_STORAGE_BUCKET=gearguard-2026reserved.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
